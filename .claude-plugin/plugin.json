{
  "name": "hybrid-loops",
  "version": "0.1.0",
  "description": "Hybrid loops: a design pattern where LLM judgment and deterministic code alternate in a mutually-constraining cycle (lens → substrate → gate → reasoner → action, plus calibration and metabolism feedback). Diagnostic-first skill plus three MCP servers for the recurring primitives: cal_log (calibration logger), metacog (cognitive-bias auditor), schemaforge (compress+verify schema discovery).",
  "author": {
    "name": "Justin Stimatze",
    "url": "https://github.com/justinstimatze"
  },
  "homepage": "https://github.com/justinstimatze/hybrid",
  "repository": {
    "type": "git",
    "url": "https://github.com/justinstimatze/hybrid"
  },
  "license": "MIT",
  "keywords": [
    "design-pattern",
    "llm-evaluator",
    "typed-substrate",
    "calibration",
    "compound-ai-systems",
    "generalization-shaping"
  ],
  "mcpServers": {
    "cal_log": {
      "command": "go",
      "args": [
        "-C",
        "${CLAUDE_PLUGIN_ROOT}/mcp_servers/cal_log",
        "run",
        "."
      ]
    },
    "metacog": {
      "command": "go",
      "args": [
        "-C",
        "${CLAUDE_PLUGIN_ROOT}/mcp_servers/metacog",
        "run",
        "."
      ]
    },
    "schemaforge": {
      "command": "go",
      "args": [
        "-C",
        "${CLAUDE_PLUGIN_ROOT}/mcp_servers/schemaforge",
        "run",
        "."
      ]
    }
  }
}
